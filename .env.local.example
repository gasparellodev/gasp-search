# =============================================================================
# Gasp Search — variáveis de ambiente
# =============================================================================
# 1. Copie este arquivo para `.env.local` (já no .gitignore).
# 2. Preencha com valores reais do Supabase, Apify e Anthropic.
# 3. Validação fail-fast em `lib/env.ts` (server) e `lib/env-public.ts` (client).
#
# NEXT_PUBLIC_* são inlinadas pelo Next em build time → expostas ao cliente.
# Demais são server-only e jamais chegam ao bundle.
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apify (https://console.apify.com/account/integrations)
APIFY_TOKEN=
APIFY_GOOGLE_MAPS_ACTOR_ID=compass~crawler-google-places
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-scraper
APIFY_WEBSITE_CONTACT_ACTOR_ID=vdrmota~contact-info-scraper

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# Evolution API (WhatsApp) — Phase 5
# =============================================================================
# Container Docker em `docker/evolution/` (ver README dessa pasta).
# Em produção: feature flag desligada (NEXT_PUBLIC_WHATSAPP_ENABLED=0) até
# subirmos VPS. EVOLUTION_API_KEY e EVOLUTION_WEBHOOK_SECRET só são obrigatórios
# quando NEXT_PUBLIC_WHATSAPP_ENABLED=1.
# =============================================================================

# URL do Evolution API (default http://localhost:8080 para dev local)
EVOLUTION_API_URL=http://localhost:8080
# Chave global do Evolution (ver docker/evolution/.env)
EVOLUTION_API_KEY=
# Secret para verificar HMAC do webhook (mín. 16 chars)
EVOLUTION_WEBHOOK_SECRET=

# Feature flag — '1' habilita UI/API de WhatsApp; '0' (default) esconde tudo.
NEXT_PUBLIC_WHATSAPP_ENABLED=0

# =============================================================================
# E2E test seed (Phase 7 — issue #166)
# =============================================================================
# Habilita a rota test-only `POST /api/e2e-seed/seed-lead-site` usada pelos
# Playwright specs em `tests/e2e/sites/`. A rota é gateada por:
#   1. NODE_ENV !== 'production' (responde 404 em prod independentemente disso).
#   2. presença de TEST_SEED_TOKEN.
#   3. ?token=<TEST_SEED_TOKEN> exato.
#
# TEST_SEED_USER_ID precisa apontar pra um usuário REAL em `auth.users` do
# Supabase de dev/test, porque `leads.user_id` é FK. Em CI essas vars são
# injetadas pela workflow de e2e (e os specs `test.skip` se ausentes).
# =============================================================================
TEST_SEED_TOKEN=
TEST_SEED_USER_ID=
