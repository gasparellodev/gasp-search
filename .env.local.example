# =============================================================================
# Gasp Search — variáveis de ambiente
# =============================================================================
# 1. Copie este arquivo para `.env.local` (já no .gitignore).
# 2. Preencha com valores reais do Supabase, Apify e Anthropic.
# 3. Validação fail-fast em `lib/env.ts` (server) e `lib/env-public.ts` (client).
#
# NEXT_PUBLIC_* são inlinadas pelo Next em build time → expostas ao cliente.
# Demais são server-only e jamais chegam ao bundle.
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apify (https://console.apify.com/account/integrations)
APIFY_TOKEN=
APIFY_GOOGLE_MAPS_ACTOR_ID=compass~crawler-google-places
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-scraper
APIFY_WEBSITE_CONTACT_ACTOR_ID=vdrmota~contact-info-scraper

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# OpenAI — Phase 7 Sprint 2 #A2 (issue #216 — visual identity generation)
# =============================================================================
# Pipeline gera 9 banners por site (1 hero + até 6 categories + 1 about + 1 contact)
# usando `gpt-image-2` (snapshot pinado). Fallback automático para
# `gpt-image-1-mini` em caso de erro persistente do modelo primário.
# DALL-E 3 será deprecada 2026-05-12 → NÃO usar como fallback.
#
# Custo target: ~$0.49 USD/cliente (1536x1024 medium hero/about/contact +
# 1024x1024 medium categories). Tier-1 default: 5 IPM rate-limit.
# =============================================================================

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Modelo primário (snapshot pinado para builds reproduzíveis)
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21

# Modelo fallback se primário falhar persistentemente
OPENAI_IMAGE_FALLBACK_MODEL=gpt-image-1-mini

# Concorrência simultânea de chamadas (Tier-1: 2; Tier-2+: 5+)
OPENAI_IMAGE_CONCURRENCY=2

# Taxa USD→BRL hardcoded V1 para `cost_estimate_brl` no manifest
BRL_RATE=5.0

# =============================================================================
# Google Maps Static API — Phase 7 #230
# =============================================================================
# Opcional. Quando vazio, /sites/<slug>/contato renderiza placeholder visual
# e link externo para Google Maps usando o endereço textual.
# Restrinja a chave no Google Cloud Console aos domínios reais do deploy:
# canônico de produção + previews Vercel aprovados.
# =============================================================================
GOOGLE_MAPS_STATIC_API_KEY=

# =============================================================================
# Redis (BullMQ) — Phase 6 issue #122
# =============================================================================
# Container Docker em `docker/redis/` (porta 6380 host → 6379 container).
# Subir: `cd docker/redis && docker compose up -d`.
# Validar: `docker exec gasp-search-redis redis-cli ping` → `PONG`.
# Consumido por `lib/queue/redis.ts` (issue #122) e `lib/whatsapp/presence.ts`
# (issue #123). NÃO tocar lib/env.ts até o PR de #122 (TDD obrigatório).
# =============================================================================
REDIS_URL=redis://localhost:6380

# =============================================================================
# IndexNow — Phase 7 #232
# =============================================================================
# Gere uma key alfanumérica e publique o arquivo `public/<INDEXNOW_KEY>.txt`
# com o mesmo conteúdo antes de habilitar em produção. Sem INDEXNOW_KEY,
# `notifyIndexNow` vira no-op e apenas registra warning PII-safe.
# =============================================================================
INDEXNOW_KEY=

# =============================================================================
# Evolution API (WhatsApp) — Phase 5
# =============================================================================
# Container Docker em `docker/evolution/` (ver README dessa pasta).
# Em produção: feature flag desligada (NEXT_PUBLIC_WHATSAPP_ENABLED=0) até
# subirmos VPS. EVOLUTION_API_KEY e EVOLUTION_WEBHOOK_SECRET só são obrigatórios
# quando NEXT_PUBLIC_WHATSAPP_ENABLED=1.
# =============================================================================

# URL do Evolution API (default http://localhost:8080 para dev local)
EVOLUTION_API_URL=http://localhost:8080
# Chave global do Evolution (ver docker/evolution/.env)
EVOLUTION_API_KEY=
# Secret para verificar HMAC do webhook (mín. 16 chars)
EVOLUTION_WEBHOOK_SECRET=

# Feature flag — '1' habilita UI/API de WhatsApp; '0' (default) esconde tudo.
NEXT_PUBLIC_WHATSAPP_ENABLED=0

# Rate-limit por usuário em POST /api/campaigns (Phase 6 / #134).
# Hard cap de campanhas criadas por hora (window de 1h em `created_at`).
# Server-only — nunca exposta ao bundle do cliente. Default 5/h.
MAX_CAMPAIGNS_PER_HOUR=5

# Phase 7 / Sprint 4 / #H3 (issue #223). Feature flag pra `<HomeContactFormQuick>`
# — quando '0' (default), o form não renderiza e `submitSiteForm` não persiste em
# `lead_form_submissions` (mantém shape MVP de stub do #161). Deploy gradual.
NEXT_PUBLIC_SITE_FORMS_ENABLED=0

# =============================================================================
# E2E test seed (Phase 7 — issue #166)
# =============================================================================
# Habilita a rota test-only `POST /api/e2e-seed/seed-lead-site` usada pelos
# Playwright specs em `tests/e2e/sites/`. A rota é gateada por:
#   1. NODE_ENV !== 'production' (responde 404 em prod independentemente disso).
#   2. presença de TEST_SEED_TOKEN.
#   3. ?token=<TEST_SEED_TOKEN> exato.
#
# TEST_SEED_USER_ID precisa apontar pra um usuário REAL em `auth.users` do
# Supabase de dev/test, porque `leads.user_id` é FK. Em CI essas vars são
# injetadas pela workflow de e2e (e os specs `test.skip` se ausentes).
# =============================================================================
TEST_SEED_TOKEN=
TEST_SEED_USER_ID=
