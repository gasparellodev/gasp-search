# Evolution API — variáveis lidas pelo docker-compose.yml.
# Copie para `docker/evolution/.env` (ignorado pelo git).

# Chave global do Evolution. Use o mesmo valor em EVOLUTION_API_KEY do
# .env.local da raiz do projeto.
AUTHENTICATION_API_KEY=troque-este-valor

# Senha do Postgres interno do Evolution.
POSTGRES_PASSWORD=troque-este-valor

# URL pública que o Evolution chama quando recebe inbound/status updates.
# Em dev: rode `ngrok http 3000` e cole aqui a URL pública gerada
# (ex.: https://abc123.ngrok.io/api/whatsapp/webhook).
# Em produção: URL pública do gasp-search.
WEBHOOK_GLOBAL_URL=https://example.ngrok.io/api/whatsapp/webhook
